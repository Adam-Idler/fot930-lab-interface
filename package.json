{
	"name": "fot930-lab-interface",
	"private": true,
	"author": "Rakov Pavel",
	"version": "1.5.0",
	"type": "commonjs",
	"main": "dist-electron/main.js",
	"build": {
		"appId": "com.fot930.lab.interface",
		"asar": true,
		"electronLanguages": [
			"ru",
			"en-US"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				},
				{
					"target": "portable",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "icon.png"
		},
		"compression": "maximum",
		"nsis": {
			"oneClick": true,
			"perMachine": false
		},
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/**/*",
			"dist-electron/*"
		]
	},
	"scripts": {
		"dev": "vite",
		"pack": "electron-builder --dir",
		"build": "vite build",
		"build:web": "vite build --config vite.web.config.ts",
		"dist": "vite build && electron-builder",
		"dist:web": "vite build --config vite.web.config.ts",
		"lint": "eslint . && biome check --write .",
		"vite:preview": "vite preview",
		"tailwind:init": "tailwindcss init -p",
		"biome:format": "biome format --write .",
		"biome:lint": "biome lint .",
		"biome:check": "biome check --write ."
	},
	"dependencies": {
		"@types/katex": "^0.16.8",
		"clsx": "^2.1.1",
		"katex": "^0.16.45",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"tailwindcss": "^4.1.16"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.2",
		"@csstools/postcss-oklab-function": "^5.0.2",
		"@eslint/js": "^9.36.0",
		"@tailwindcss/vite": "^4.1.16",
		"@types/node": "^24.6.0",
		"@types/react": "^19.1.16",
		"@types/react-dom": "^19.1.9",
		"@vitejs/plugin-react": "^5.0.4",
		"electron": "^39.0.0",
		"electron-builder": "^26.0.12",
		"eslint": "^9.36.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.22",
		"globals": "^16.4.0",
		"terser": "^5.46.1",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.45.0",
		"vite": "^7.1.7",
		"vite-plugin-electron": "^0.29.0",
		"vite-plugin-electron-renderer": "^0.14.6"
	}
}
